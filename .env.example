# Flask core
SECRET_KEY=change-me
SQLALCHEMY_DATABASE_URI=mysql+mysqlconnector://root@localhost/shortletdb

# CORS
CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# JWT
JWT_SECRET_KEY=change-me-jwt
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRES_DAYS=14
JWT_ISSUER=verified-shortlet-api
JWT_AUDIENCE=verified-shortlet-client
JWT_CLOCK_SKEW_SECONDS=30

# Upload limits
MAX_CONTENT_LENGTH=6291456
MAX_UPLOAD_FILE_BYTES=5242880
ALLOWED_UPLOAD_EXTENSIONS=jpg,jpeg,png,webp
ALLOWED_UPLOAD_MIME_TYPES=image/jpeg,image/png,image/webp

# Paystack (optional in local development)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
PAYSTACK_CALLBACK_URL=
PAYSTACK_WEBHOOK_URL=
